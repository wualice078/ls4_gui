# Copy to .env and edit only what differs from your machine.
# Defaults match the La Silla mountain layout (ls4-workstn / ls4-nuc).

# --- Required on any deployed machine ---
LS4_GUI_SECRET_KEY=replace-with-a-long-random-string
LS4_GUI_PASSWORD=choose-a-strong-password

# --- Safety ---
# true  = no real hardware (default)
# false = live start_questctl, opendome, PDU, mosaics, etc.
LS4_GUI_SIMULATE=true

# --- Core mountain paths ---
LS4_OBSERVER_HOME=/home/observer
LS4_KENNETH_DIR=/home/ls4/kenneth
LS4_DATA_DIR=/data/observer

# --- Camera / snapshot paths ---
LS4_FLUX_METER_SNAPSHOT_DIR=/home/ls4/snapshots
LS4_TCS_WEBCAM_DIR=/home/ls4/kenneth
LS4_OIL_PUMP_IMAGE_DIR=/home/ls4/kenneth

# --- GUI sim cache (webcam placeholders, mosaic previews, PDU sim state) ---
LS4_SIM_DIR=/home/observer/sim
LS4_SIM_STATE_FILE=/home/observer/sim/state.json
LS4_SIM_WEBCAM_DIR=/home/observer/sim/webcams
LS4_MOSAIC_PREVIEW_DIR=/home/observer/sim/mosaics

# --- External scripts (override if tools move) ---
LS4_PDU_SCRIPT=/home/ls4/kenneth/pdu_api.py
LS4_TCS_WEBCAM_SCRIPT=/home/ls4/kenneth/TCS_webcam.py
LS4_OIL_PUMP_CAPTURE_SCRIPT=/home/ls4/kenneth/webpump_capture.py

# --- Observer shell environment ---
LS4_OBSERVER_BIN_DIR=/home/observer/bin
LS4_OBSERVER_TCSHRC=/home/observer/.tcshrc
LS4_OBS_CONTROL_SCRIPT=/home/observer/bin/obs_control_script
LS4_GUI_PYTHON=python3

# --- Web server / login ---
LS4_GUI_HOST=0.0.0.0
LS4_GUI_PORT=8080
LS4_GUI_USERNAME=observer

# --- UI links / workflow ---
LS4_DOME_TRANSITION_SECONDS=90
LS4_AWS_SERVER_URL=http://32.195.133.207/
LS4_WEBCAM_REFRESH_SECONDS=30
LS4_OPERATOR_PDU_OUTLETS=1,2,3,4,8
LS4_LOGBOOK_URL=https://docs.google.com/document/d/1TfwjvCbK3iwrGQz7A78CSYDjfwSEA4Grl423T3Ru5Ss/edit
LS4_ENABLE_SCHEDULER_PAUSE=false

# --- Local VM overrides (uncomment instead of the mountain paths above) ---
# LS4_OBSERVER_HOME=/home/ls4/code/observer-home
# LS4_KENNETH_DIR=/home/ls4/code/observer-home/kenneth
# LS4_FLUX_METER_SNAPSHOT_DIR=/home/ls4/code/observer-home/snapshots
# LS4_SIM_DIR=/home/ls4/code/observer-home/sim
# LS4_SIM_STATE_FILE=/home/ls4/code/observer-home/sim/state.json
# LS4_SIM_WEBCAM_DIR=/home/ls4/code/observer-home/sim/webcams
# LS4_MOSAIC_PREVIEW_DIR=/home/ls4/code/observer-home/sim/mosaics
# LS4_GUI_PYTHON=/home/ls4/ls4_venv/bin/python
