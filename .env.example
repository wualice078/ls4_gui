# cp .env.example .env  then set SECRET_KEY and PASSWORD

# --- Required ---
LS4_GUI_SECRET_KEY=replace-with-a-long-random-string
LS4_GUI_PASSWORD=choose-a-strong-password
LS4_GUI_SIMULATE=true

# --- Paths ---
LS4_OBSERVER_HOME=/home/observer
LS4_KENNETH_DIR=/home/ls4/kenneth
LS4_DATA_DIR=/data/observer
LS4_FLUX_METER_SNAPSHOT_DIR=/home/ls4/snapshots
LS4_TCS_WEBCAM_DIR=/home/ls4/kenneth
LS4_OIL_PUMP_IMAGE_DIR=/home/ls4/snapshots
LS4_OIL_PUMP_CAM_TAG=cam2
LS4_OIL_PUMP_SYNC_ENABLED=false
LS4_OIL_PUMP_REMOTE_HOST=ls4@192.168.1.74
LS4_OIL_PUMP_REMOTE_DIR=/home/ls4/snapshots
LS4_OIL_PUMP_SSH_KEY=/home/observer/.ssh/id_ed25519_ls4snap
LS4_READ_PRESSURE_SCRIPT=/home/ls4/kenneth/read_pressure.py
LS4_PRESSURE_LOG_FILE=/home/ls4/kenneth/pressure_log.txt
LS4_OIL_PUMP_RENDER_OUTPUT=/home/observer/sim/webcams/oil_pump_latest.svg
LS4_SIM_DIR=/home/observer/sim
LS4_SIM_STATE_FILE=/home/observer/sim/state.json
LS4_SIM_WEBCAM_DIR=/home/observer/sim/webcams
LS4_MOSAIC_PREVIEW_DIR=/home/observer/sim/mosaics

# --- Scripts ---
LS4_PDU_SCRIPT=/home/ls4/kenneth/pdu_api.py
LS4_TCS_WEBCAM_SCRIPT=/home/ls4/kenneth/TCS_webcam.py
LS4_OIL_PUMP_CAPTURE_SCRIPT=/home/observer/ls4_gui/scripts/render_oil_pump_pressure.py
LS4_OBSERVER_BIN_DIR=/home/observer/bin
LS4_OBSERVER_TCSHRC=/home/observer/.tcshrc
LS4_OBS_CONTROL_SCRIPT=/home/observer/bin/obs_control_script
LS4_GUI_PYTHON=/home/observer/observer_venv/bin/python

# --- Server ---
LS4_GUI_HOST=0.0.0.0
LS4_GUI_PORT=8080
LS4_GUI_USERNAME=observer

# --- Dashboard ---
LS4_DOME_TRANSITION_SECONDS=90
LS4_WEBCAM_REFRESH_SECONDS=30
LS4_OPERATOR_PDU_OUTLETS=1,2,3,4,8
LS4_ENABLE_SCHEDULER_PAUSE=false
LS4_AWS_SERVER_URL=http://32.195.133.207/
LS4_LOGBOOK_URL=https://docs.google.com/document/d/1TfwjvCbK3iwrGQz7A78CSYDjfwSEA4Grl423T3Ru5Ss/edit
